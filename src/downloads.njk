---
layout: base.njk
title: Downloads — Boberger Reitverein Hamburg
navActive: downloads
---

<div class="page-hero" style="background-image: url('{{ downloadPage.heroBildUrl or '/images/foto-schleife.jpg' }}'); background-size: cover; background-position: center;">
  <div class="page-hero-bg" style="opacity: 1; background: linear-gradient(160deg, rgba(13,26,51,0.78) 0%, rgba(26,58,107,0.68) 45%, rgba(10,18,40,0.80) 100%);"></div>
  <div class="page-hero-content">
    <h1 class="page-title" style="font-size: clamp(48px, 8vw, 96px);">Downloads</h1>
    <p class="page-subtitle">{{ downloadPage.heroSubtitel or 'Formulare, Dokumente &amp; Stundenpläne' }}</p>
  </div>
</div>

<div class="page-content">

  {% set kategorien = downloads | groupby('kategorie') %}
  {% for kategorie, items in kategorien %}
  <div class="downloads-section reveal">
    <h2 class="dl-category-title">{{ kategorie }}</h2>
    <ul class="dl-list">
      {% for item in items %}
      <li class="dl-item">
        {% if item.dateiUrl %}
          <div class="dl-info">
            <div class="dl-name">{{ item.name }}</div>
            {% if item.datum %}<div class="dl-desc">Stand: {{ item.datum }}</div>{% endif %}
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <span class="dl-tag">PDF</span>
            <a href="{{ item.dateiUrl }}" target="_blank" rel="noopener" class="dl-btn" download>Herunterladen ↓</a>
          </div>
        {% else %}
          <div class="dl-info">
            <div class="dl-name">{{ item.name }} (bald verfügbar)</div>
          </div>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
  {% endfor %}


</div>
