---
layout: base.njk
title: Team — Boberger Reitverein Hamburg
navActive: verein
---

<div class="page-hero" style="background-image: url('{{ vorstandPage.heroBildUrl or '/images/TeamFotoBalken.jpeg' }}'); background-size: cover; background-position: {{ vorstandPage.heroBildHotspot | hotspotPosition('center 30%') }};">
  <div class="page-hero-bg" style="opacity: 1; background: linear-gradient(160deg, rgba(13,26,51,0.78) 0%, rgba(26,58,107,0.68) 45%, rgba(10,18,40,0.80) 100%);"></div>
  <div class="page-hero-content">
    <h1 class="page-title">Team</h1>
    <p class="page-subtitle">{{ vorstandPage.heroSubtitel or 'Der Boberger Reitverein Hamburg e.V. — Gegründet 1968' }}</p>
  </div>
</div>

<div class="page-content">

  <!-- Group Photo + Caption -->
  <p class="section-label reveal">Vorstand</p>
  <div class="gruppe-foto-wrap reveal">
    <div class="gruppe-foto">
      {% if vorstandPage.gruppenFotoUrl %}
        <img src="{{ vorstandPage.gruppenFotoUrl }}" alt="Gruppenfoto Vereinsvorstand" loading="lazy" onerror="this.style.display='none'" style="object-position: {{ vorstandPage.gruppenFotoHotspot | hotspotPosition }};" />
      {% else %}
        <img src="/images/vorstand/Gruppenfoto.jpg" alt="Gruppenfoto Vereinsvorstand" loading="lazy" onerror="this.style.display='none'" />
        <span class="gruppe-foto-hint">Gruppenfoto Vereinsvorstand</span>
      {% endif %}
    </div>
    <div class="gruppe-foto-caption">
      {% if vorstandPage.gruppenFotoBeschriftung %}{{ vorstandPage.gruppenFotoBeschriftung }}{% else %}Christiane Feist (Vorsitzende) &nbsp;|&nbsp; Isabelle Haesler (Stellv. Vorsitzende) &nbsp;|&nbsp; Katharina Lechelt (Schatzmeisterin) &nbsp;|&nbsp; Lilli Schmidt (Jugendwartin) &nbsp;|&nbsp; Janine Band (Technische Leiterin){% endif %}
    </div>
  </div>

  <!-- Betriebsleitung -->
  <p class="section-label reveal">Betriebsleitung</p>
  <div class="betrieb-wrap reveal">
    <div class="betrieb-card">
      <div class="beauftragte-photo">
        {% if vorstandPage.betriebsleiterinFotoUrl %}
          <img src="{{ vorstandPage.betriebsleiterinFotoUrl }}" alt="{{ vorstandPage.betriebsleiterinName or 'Stefanie Gontard' }}" loading="lazy" onerror="this.style.display='none'" style="object-position: {{ vorstandPage.betriebsleiterinFotoHotspot | hotspotPosition }};" />
        {% else %}
          <img src="/images/vorstand/StefanieGontard.jpg" alt="Stefanie Gontard" loading="lazy" onerror="this.style.display='none'" />
        {% endif %}
      </div>
      <div class="beauftragte-caption">
        <div class="beauftragte-name">{{ vorstandPage.betriebsleiterinName or 'Stefanie Gontard' }}</div>
        <div class="beauftragte-role">{{ vorstandPage.betriebsleiterinRolle or 'Betriebsleiterin' }}</div>
      </div>
    </div>
  </div>

  <!-- Beauftragte (from Sanity — only shown when records exist) -->
  {% if vorstand | length %}
  <p class="section-label reveal">Beauftragte</p>
  <div class="beauftragte-grid reveal">
    {% for mitglied in vorstand %}
    <div class="beauftragte-card">
      <div class="beauftragte-photo">
        {% if mitglied.fotoUrl %}
          <img src="{{ mitglied.fotoUrl }}" alt="{{ mitglied.name }}" loading="lazy" style="object-position: {{ mitglied.fotoHotspot | hotspotPosition }};">
        {% else %}
          <div class="vorstand-placeholder" style="width:100%;height:100%;background:linear-gradient(135deg,#1C3A2A,#0a1208);"></div>
        {% endif %}
      </div>
      <div class="beauftragte-caption">
        <div class="beauftragte-name">{{ mitglied.name }}</div>
        <div class="beauftragte-role">{{ mitglied.rolle }}</div>
      </div>
    </div>
    {% endfor %}
  </div>
  {% endif %}

  <!-- Satzung -->
  <p class="section-label reveal">Vereinsdokumente</p>
  <div class="satzung-banner reveal">
    <div class="satzung-text">
      <h3>Vereinssatzung</h3>
      <p>{{ vorstandPage.satzungBeschreibung or 'Die Satzung des Boberger Reitverein Hamburg e.V. steht als PDF zum Download bereit.' }}</p>
    </div>
    <a href="/downloads/" class="btn">Zur Satzung →</a>
  </div>

  <!-- Mitglied werden -->
  <p class="section-label reveal">Mitglied werden</p>
  <div class="mitglied-box reveal">
    <div>
      <h2 class="mitglied-heading">{{ vorstandPage.mitgliedUeberschrift or 'Teil des BRV werden' }}</h2>
    </div>
    <div>
      <p class="mitglied-text">
        {{ vorstandPage.mitgliedText or 'Der Boberger Reitverein ist offen für alle, die Freude am Reiten und an der Gemeinschaft haben. Die Beitrittserklärung steht unter Downloads zum Herunterladen bereit. Bei Fragen stehen wir gerne persönlich zur Verfügung.' }}
      </p>
      <div style="display:flex;gap:16px;flex-wrap:wrap;">
        <a href="/downloads/" class="btn btn-dark">Beitrittserklärung →</a>
        <a href="/#kontakt" class="btn btn-dark">Kontakt aufnehmen</a>
      </div>
    </div>
  </div>

</div>
