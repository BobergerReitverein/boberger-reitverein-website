---
layout: base.njk
title: Aktuelles — Boberger Reitverein Hamburg
navActive: aktuelles
---

<div class="page-hero" style="background-image: url('/images/Stangen.jpg'); background-size: cover; background-position: center;">
  <div class="page-hero-bg" style="opacity: 1; background: linear-gradient(160deg, rgba(13,26,51,0.78) 0%, rgba(26,58,107,0.68) 45%, rgba(10,18,40,0.80) 100%);"></div>
  <div class="page-hero-content">
    <h1 class="page-title">Aktuelles</h1>
    <p class="page-subtitle">Neuigkeiten, Veranstaltungen &amp; Ankündigungen</p>
  </div>
</div>

<div class="page-content">

  <p class="section-label reveal">Aktuelles 2026</p>

  <div class="aktuelles-grid">
    {% for post in aktuelles %}
    <article class="news-card reveal">
      <div class="news-date">{{ post.kategorie }}</div>
      <h3 class="news-title">{{ post.titel }}</h3>
      <p class="news-excerpt">{{ post.auszug }}</p>
      <a href="/aktuelles/" class="news-link">Mehr erfahren →</a>
    </article>
    {% endfor %}
  </div>

  <!-- Kontakt CTA -->
  <div class="aktuelles-cta">
    <div>
      <p style="font-family:var(--font-body);font-weight:200;font-size:9px;letter-spacing:0.38em;text-transform:uppercase;color:var(--green);margin-bottom:10px;">Allgemeine Anfragen</p>
      <h3 style="font-family:var(--font-display);font-size:20px;letter-spacing:0.04em;margin-bottom:6px;">Fragen zu unseren Ankündigungen?</h3>
      <p style="font-weight:300;font-size:13px;color:#555;line-height:1.7;">Wir helfen dir gerne weiter — per Telefon oder E-Mail.</p>
    </div>
    <div style="display:flex;gap:16px;flex-wrap:wrap;">
      <a href="tel:+494073340552" class="btn">040 7340552</a>
      <a href="mailto:info@boberger-reitverein.de" class="btn">E-Mail schreiben</a>
    </div>
  </div>

</div>
