---
layout: base.njk
title: Anlage — Boberger Reitverein Hamburg
navActive: verein
---

<div class="page-hero" style="background-image: url('{{ anlagePage.heroBildUrl or '/images/Hintergrundkontakt.jpg' }}'); background-size: cover; background-position: center;">
  <div class="page-hero-bg" style="opacity: 1; background: linear-gradient(160deg, rgba(13,26,51,0.78) 0%, rgba(26,58,107,0.68) 45%, rgba(10,18,40,0.80) 100%);"></div>
  <div class="page-hero-content">
    <h1 class="page-title">Anlage</h1>
    <p class="page-subtitle">Moderne Infrastruktur — mitten in der Boberger Niederung</p>
  </div>
</div>

<div class="page-content">

  <p class="section-label reveal">Unsere Anlage</p>

  <div class="anlage-intro reveal">
    <h2 class="anlage-intro-heading">{{ anlagePage.introTitel or 'Optimale Bedingungen für Pferd und Reiter' }}</h2>
    <div>
      {% if anlagePage.introAbsaetze %}
        {% for absatz in anlagePage.introAbsaetze %}
          <p class="anlage-intro-body">{{ absatz }}</p>
        {% endfor %}
      {% else %}
        <p class="anlage-intro-body">Unsere Anlage besteht aus mehreren Stallbereichen, zwei Reithallen mit moderner Beregnungsanlage, einem Dressur- und einem Springplatz, einem Roundpen, Sandpaddocks und den Weiden. Besonderes Schmuckstück ist das reetgedeckte denkmalgeschützte Hufnerhaus, in dem sich auch das Café-Restaurant „Alte Deichkate" befindet.</p>
        <p class="anlage-intro-body">Als Verein sind wir selbst für den Zustand der Anlage verantwortlich und bringen durch das tatkräftige Engagement unserer Mitglieder unseren Hof nach und nach auf Vordermann!</p>
      {% endif %}
    </div>
  </div>

  {% if anlagePage.galerie %}
    <div class="photo-gallery reveal">
      {% for foto in anlagePage.galerie %}
        <div class="gal-cell">
          <img src="{{ foto.bildUrl }}" alt="{{ foto.beschriftung }}" class="gal-img" loading="lazy" />
          <div class="gal-label">{{ foto.beschriftung }}</div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="photo-gallery reveal">
      <div class="gal-cell">
        <img src="/images/anlage-einfahrt.jpg" alt="Einfahrt" class="gal-img" loading="lazy" />
        <div class="gal-label">Reithalle</div>
      </div>
      <div class="gal-cell">
        <img src="/images/stall-halle-eingang.jpg" alt="Stall & Halleneingang" class="gal-img" loading="lazy" />
        <div class="gal-label">Stall &amp; Halleneingang</div>
      </div>
      <div class="gal-cell">
        <img src="/images/anlage-stall.jpg" alt="Stallbereich" class="gal-img" loading="lazy" />
        <div class="gal-label">Springplatz</div>
      </div>
      <div class="gal-cell">
        <img src="/images/anlage-stall-building.jpg" alt="Stallgebäude" class="gal-img" loading="lazy" />
        <div class="gal-label">Stallgebäude</div>
      </div>
      <div class="gal-cell">
        <img src="/images/Roundpen.jpg" alt="Roundpen" class="gal-img" loading="lazy" />
        <div class="gal-label">Roundpen</div>
      </div>
      <div class="gal-cell">
        <img src="/images/Hallehinten.jpg" alt="Reithalle" class="gal-img" loading="lazy" />
        <div class="gal-label">Haupthaus mit Stall</div>
      </div>
    </div>
  {% endif %}

  <div class="anlage-banner reveal">
    <img src="{{ anlagePage.bannerBildUrl or '/images/Stangen.jpg' }}" alt="Springanlage" loading="lazy" />
  </div>

  <p class="section-label reveal">Einrichtungen</p>

  {% if anlagePage.einrichtungen %}
    <div class="facility-grid reveal">
      {% for einrichtung in anlagePage.einrichtungen %}
        <div class="facility-item">
          <div class="facility-num">{{ einrichtung.anzahl }}</div>
          <div class="facility-title">{{ einrichtung.titel }}</div>
          <p class="facility-text">{{ einrichtung.beschreibung }}</p>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="facility-grid reveal">
      <div class="facility-item">
        <div class="facility-num">2</div>
        <div class="facility-title">Reithallen</div>
        <p class="facility-text">Zwei Reithallen ermöglichen ganzjährigen Unterricht und Training — unabhängig von Witterung und Jahreszeit.</p>
      </div>
      <div class="facility-item">
        <div class="facility-num">1</div>
        <div class="facility-title">Roundpen</div>
        <p class="facility-text">Der Roundpen bietet ideale Bedingungen für Longen- und Freiarbeit.</p>
      </div>
      <div class="facility-item">
        <div class="facility-num">1</div>
        <div class="facility-title">Dressurplatz</div>
        <p class="facility-text">Dressurplatz (großes Viereck) im Außenbereich.</p>
      </div>
      <div class="facility-item">
        <div class="facility-num">1</div>
        <div class="facility-title">Springplatz</div>
        <p class="facility-text">Großer Rasenplatz mit festen und variablen Hindernissen, Wällen und Tiefsprung.</p>
      </div>
      <div class="facility-item">
        <div class="facility-num">1</div>
        <div class="facility-title">Solarium</div>
        <p class="facility-text">Das Pferdesolarium unterstützt Muskelentspannung und Regeneration.</p>
      </div>
      <div class="facility-item">
        <div class="facility-num">2</div>
        <div class="facility-title">Waschplätze</div>
        <p class="facility-text">Eine Waschbox im Innenbereich mit Warmwasser und ein Waschplatz im Außenbereich.</p>
      </div>
    </div>
  {% endif %}

</div>
